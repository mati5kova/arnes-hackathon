# Shared Azure OpenAI defaults.
# You can use these for every model, or override per model below.
AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_API_KEY=

# Optional override if you want the chat assistant to read a different local risk dataset.
# CHAT_RISK_DATA_FILE=/absolute/path/to/kd_z_nevarnost_enriched_verified.geojson
# Optional override for persisted per-model usage totals.
# CHAT_USAGE_SUMMARY_FILE=/absolute/path/to/chat-usage-summary.json

# Model registry for the chat sidebar.
# Each model can override BASE_URL / API_KEY / ENDPOINT individually if needed.

CHAT_MODEL_MDML_GPT4_1_MINI_001_DEPLOYMENT=MDML-GPT4.1-Mini-001
CHAT_MODEL_MDML_GPT4_1_MINI_001_API_KEY=
CHAT_MODEL_MDML_GPT4_1_MINI_001_BASE_URL=

